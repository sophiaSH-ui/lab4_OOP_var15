<Window x:Class="lab4_oop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gravity Auto Прокат" Height="550" Width="420"
        WindowStartupLocation="CenterScreen"
        Background="#F3E8DF">

    <Window.Resources>
        <SolidColorBrush x:Key="CardBg" Color="#E8D1C5"/>
        <SolidColorBrush x:Key="HeaderBg" Color="#452829"/>
        <SolidColorBrush x:Key="AccentMain" Color="#57595B"/>
        <SolidColorBrush x:Key="AccentMainHover" Color="#3C3D3F"/>
        <SolidColorBrush x:Key="DarkText" Color="#452829"/>
        <SolidColorBrush x:Key="MutedText" Color="#57595B"/>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource HeaderBg}" CornerRadius="20" Padding="0,30" Margin="0,0,0,20">
            <Border.Effect>
                <DropShadowEffect Color="#452829" BlurRadius="15" ShadowDepth="4" Opacity="0.3" Direction="270"/>
            </Border.Effect>
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="✨ Gravity Auto" Foreground="#F3E8DF" FontSize="38" FontWeight="Heavy" FontFamily="Segoe UI" HorizontalAlignment="Center"/>
                <TextBlock Text="АВТОПРОКАТ &amp; КОТИКИ" Foreground="#E8D1C5" FontSize="11" FontWeight="Bold" FontFamily="Segoe UI" HorizontalAlignment="Center" Margin="0,6,0,0"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="10,0">

            <Button Content="🚘  Довідник авто" Foreground="#F3E8DF" Height="64" Margin="0,0,0,16" Cursor="Hand" Click="OpenCars_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{StaticResource AccentMain}" CornerRadius="16">
                            <Border.Effect>
                                <DropShadowEffect Color="#57595B" BlurRadius="15" ShadowDepth="4" Opacity="0.4" Direction="270"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" TextBlock.FontWeight="Bold" TextBlock.FontSize="18"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentMainHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button Content="🐱  Котики" Foreground="{StaticResource DarkText}" Height="64" Margin="0,0,0,16" Cursor="Hand" Click="OpenKitties_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{StaticResource CardBg}" CornerRadius="16">
                            <Border.Effect>
                                <DropShadowEffect Color="#452829" BlurRadius="10" ShadowDepth="3" Opacity="0.2" Direction="270"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" TextBlock.FontWeight="SemiBold" TextBlock.FontSize="18"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#DCC2B4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button Content="👋  Бувай!" Foreground="{StaticResource MutedText}" Height="50" Cursor="Hand" Click="Exit_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="Transparent" CornerRadius="16" BorderThickness="1.5" BorderBrush="#57595B">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" TextBlock.FontWeight="SemiBold" TextBlock.FontSize="16"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource CardBg}"/>
                                <Setter Property="Foreground" Value="{StaticResource DarkText}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

        </StackPanel>

        <TextBlock Grid.Row="2" Text="© Gravity Auto 2026" Foreground="{StaticResource MutedText}" FontSize="12" HorizontalAlignment="Center" Margin="0,15,0,0"/>
    </Grid>
</Window>