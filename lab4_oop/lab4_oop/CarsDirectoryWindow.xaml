<Window x:Class="lab4_oop.CarsDirectoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Довідник автомобілів" Height="450" Width="850"
        WindowStartupLocation="CenterScreen"
        Background="#F3E8DF">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Список оформлених транспортних засобів" FontSize="20" FontWeight="Bold" Foreground="#452829" Margin="0,0,0,10" Grid.Row="0"/>

        <DataGrid x:Name="GridCars" Grid.Row="1" AutoGenerateColumns="False" 
                  CanUserAddRows="False" IsReadOnly="True" SelectionMode="Single"
                  Background="#E8D1C5" RowBackground="White" AlternatingRowBackground="#F9F5F3"
                  SelectionChanged="GridCars_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Виробник" Binding="{Binding Car.Manufacturer}" Width="*"/>
                <DataGridTextColumn Header="Модель" Binding="{Binding Car.Model}" Width="*"/>
                <DataGridTextColumn Header="Категорія" Binding="{Binding Category}" Width="100"/>
                <DataGridTextColumn Header="Номерний знак" Binding="{Binding LicensePlate}" Width="100"/>
                <DataGridTextColumn Header="Початок" Binding="{Binding RentalStartDate, StringFormat=dd.MM.yyyy}" Width="80"/>
                <DataGridTextColumn Header="Днів" Binding="{Binding RentalDurationDays}" Width="50"/>
                <DataGridTextColumn Header="Вартість ($)" Binding="{Binding RentalPrice}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Додати" Width="100" Height="35" Margin="0,0,10,0" Background="#57595B" Foreground="#F3E8DF" Cursor="Hand" Click="AddCar_Click"/>
            <Button x:Name="btnEdit" Content="Редагувати" Width="100" Height="35" Margin="0,0,10,0" Background="#57595B" Foreground="#F3E8DF" Cursor="Hand" IsEnabled="False" Click="EditCar_Click"/>
            <Button x:Name="btnDelete" Content="Видалити" Width="100" Height="35" Background="#452829" Foreground="White" Cursor="Hand" IsEnabled="False" Click="DeleteCar_Click"/>
        </StackPanel>
    </Grid>
</Window>