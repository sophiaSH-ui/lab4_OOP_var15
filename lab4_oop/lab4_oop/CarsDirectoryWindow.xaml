<Window x:Class="lab4_oop.CarsDirectoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Довідник автомобілів" Height="480" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#F3E8DF">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <Button Content="← Назад до головного меню" HorizontalAlignment="Left" Background="Transparent" 
                    BorderThickness="0" Foreground="#57595B" FontWeight="Bold" Cursor="Hand" 
                    Click="Back_Click" Margin="0,0,0,10"/>
            <TextBlock Text="Список оформлених транспортних засобів" FontSize="20" FontWeight="Bold" Foreground="#452829"/>
        </StackPanel>

        <DataGrid x:Name="GridCars" Grid.Row="1" AutoGenerateColumns="False" 
                  CanUserAddRows="False" IsReadOnly="True" SelectionMode="Single" 
                  Background="#E8D1C5" RowBackground="White" AlternatingRowBackground="#F9F5F3" 
                  SelectionChanged="GridCars_SelectionChanged"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  ScrollViewer.VerticalScrollBarVisibility="Auto">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Виробник" Binding="{Binding Car.Manufacturer}" Width="150"/>
                <DataGridTextColumn Header="Модель" Binding="{Binding Car.Model}" Width="150"/>
                <DataGridTextColumn Header="Категорія" Binding="{Binding Category}" Width="120"/>
                <DataGridTextColumn Header="Номерний знак" Binding="{Binding LicensePlate}" Width="130"/>
                <DataGridTextColumn Header="Дата початку" Binding="{Binding RentalStartDate, StringFormat=dd.MM.yyyy}" Width="120"/>
                <DataGridTextColumn Header="Днів" Binding="{Binding RentalDurationDays}" Width="80"/>
                <DataGridTextColumn Header="Ціна прокату" Binding="{Binding RentalPrice}" Width="110"/>
                <DataGridCheckBoxColumn Header="Виконано" Binding="{Binding IsCompleted}" Width="90"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Додати" Width="100" Height="35" Margin="0,0,10,0" Background="#57595B" Foreground="#F3E8DF" Click="AddCar_Click"/>
            <Button x:Name="btnEdit" Content="Редагувати" Width="100" Height="35" Margin="0,0,10,0" Background="#57595B" Foreground="#F3E8DF" IsEnabled="False" Click="EditCar_Click"/>
            <Button x:Name="btnDelete" Content="Видалити" Width="100" Height="35" Background="#452829" Foreground="White" IsEnabled="False" Click="DeleteCar_Click"/>
        </StackPanel>
    </Grid>
</Window>