<Window x:Class="lab4_oop.CarsDirectoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Довідник автомобілів" Height="600" Width="850"
        WindowStartupLocation="CenterScreen"
        Background="#F3E8DF">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <Button Content="← Назад до меню" HorizontalAlignment="Left" Background="Transparent" 
                    BorderThickness="0" Foreground="#57595B" FontWeight="Bold" Cursor="Hand" 
                    Click="Back_Click" Margin="0,0,0,10"/>
            <TextBlock x:Name="txtFullInfo" FontSize="18" FontWeight="Bold" Foreground="#452829"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Оберіть прокат:" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#452829" Margin="0,0,10,0"/>
            <ComboBox x:Name="cmbCompanies" Width="200" Height="30" DisplayMemberPath="CompanyName" SelectionChanged="cmbCompanies_SelectionChanged" Background="#E8D1C5"/>
            <TextBox x:Name="txtNewCompanyName" Width="150" Height="30" Margin="20,0,10,0" Padding="5" Background="#E8D1C5"/>
            <Button Content="Додати фірму" Width="110" Height="30" Background="#57595B" Foreground="#F3E8DF" Cursor="Hand" Click="AddCompany_Click"/>
        </StackPanel>

        <DataGrid x:Name="GridCars" Grid.Row="2" AutoGenerateColumns="False" 
                  CanUserAddRows="False" IsReadOnly="True" SelectionMode="Single" 
                  Background="#E8D1C5" RowBackground="White" AlternatingRowBackground="#F9F5F3" 
                  SelectionChanged="GridCars_SelectionChanged"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  ScrollViewer.VerticalScrollBarVisibility="Auto">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Виробник" Binding="{Binding Car.Manufacturer}" Width="130"/>
                <DataGridTextColumn Header="Модель" Binding="{Binding Car.Model}" Width="130"/>
                <DataGridTextColumn Header="Категорія" Binding="{Binding Category}" Width="100"/>
                <DataGridTextColumn Header="Номер" Binding="{Binding LicensePlate}" Width="100"/>
                <DataGridTextColumn Header="Рік авто" Binding="{Binding Car.Year}" Width="80"/>
                <DataGridTextColumn Header="Ціна авто" Binding="{Binding Car.Price}" Width="90"/>
                <DataGridTextColumn Header="Початок" Binding="{Binding RentalStartDate, StringFormat=dd.MM.yyyy}" Width="100"/>
                <DataGridTextColumn Header="Днів" Binding="{Binding RentalDurationDays}" Width="60"/>
                <DataGridTextColumn Header="Ціна прокату" Binding="{Binding RentalPrice}" Width="100"/>
                <DataGridCheckBoxColumn Header="ОК" Binding="{Binding IsCompleted}" Width="50"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="3" Background="#E8D1C5" CornerRadius="8" Padding="12" Margin="0,15,0,0">
            <TextBlock x:Name="txtShortSummary" Foreground="#452829" FontWeight="Medium" FontStyle="Italic" FontSize="13"/>
        </Border>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Додати авто" Width="110" Height="38" Margin="0,0,10,0" Background="#57595B" Foreground="#F3E8DF" Cursor="Hand" Click="AddCar_Click"/>
            <Button x:Name="btnEdit" Content="Редагувати" Width="110" Height="38" Margin="0,0,10,0" IsEnabled="False" Cursor="Hand" Click="EditCar_Click"/>
            <Button x:Name="btnDelete" Content="Видалити" Width="110" Height="38" Background="#452829" IsEnabled="False" Cursor="Hand" Click="DeleteCar_Click"/>
        </StackPanel>
    </Grid>
</Window>